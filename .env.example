# Authentication (Google OAuth)
AUTH_SECRET=  # Generate with: openssl rand -base64 33
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Database (Neon PostgreSQL via Vercel)
# These are auto-added by Vercel when you connect a Neon database.
# For local dev, copy the values from Vercel → Project Settings → Environment Variables.
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
